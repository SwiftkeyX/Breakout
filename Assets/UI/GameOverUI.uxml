<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements">
  <ui:VisualElement name="root" style="width: 100%; height: 100%; justify-content: center; align-items: center; background-color: rgb(18, 18, 18);">
    <ui:Label name="result-label" text="GAME OVER" style="font-size: 96px; color: white; margin-bottom: 16px; -unity-font-style: bold;" />
    <ui:Label name="score-label" text="SCORE  0" style="font-size: 48px; color: rgb(160, 160, 160); margin-bottom: 48px;" />
    <ui:Button name="restart-button" text="PLAY AGAIN" style="margin-bottom: 12px; padding: 12px 40px; font-size: 36px; background-color: rgb(40, 40, 40); border-color: rgb(80, 80, 80); border-width: 1px; color: white;" />
    <ui:Button name="menu-button" text="MAIN MENU" style="padding: 12px 40px; font-size: 36px; background-color: rgb(40, 40, 40); border-color: rgb(80, 80, 80); border-width: 1px; color: white;" />
  </ui:VisualElement>
</ui:UXML>
